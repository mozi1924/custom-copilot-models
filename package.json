{
  "name": "responses-copilot",
  "displayName": "Responses Copilot",
  "description": "Use OpenAI-compatible Responses API models directly in the Copilot Chat model picker with native image input and tool calling.",
  "icon": "resources/icon.png",
  "version": "0.1.0",
  "publisher": "mozi1924",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mozi1924/custom-copilot-models"
  },
  "engines": {
    "vscode": "^1.116.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat",
    "Programming Languages"
  ],
  "keywords": [
    "responses",
    "openai",
    "copilot",
    "github copilot",
    "copilot chat",
    "vision",
    "byok",
    "language model",
    "thinking",
    "reasoning",
    "ai",
    "chat"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "enabledApiProposals": [],
  "main": "./out/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "responses-copilot",
        "displayName": "Responses Copilot",
        "managementCommand": "responses-copilot.openSettings"
      }
    ],
    "commands": [
      {
        "command": "responses-copilot.setApiKey",
        "title": "%responses-copilot.command.setApiKey%"
      },
      {
        "command": "responses-copilot.getApiKey",
        "title": "%responses-copilot.command.getApiKey%"
      },
      {
        "command": "responses-copilot.clearApiKey",
        "title": "%responses-copilot.command.clearApiKey%"
      },
      {
        "command": "responses-copilot.refreshModels",
        "title": "%responses-copilot.command.refreshModels%"
      },
      {
        "command": "responses-copilot.openSettings",
        "title": "%responses-copilot.command.openSettings%"
      },
      {
        "command": "responses-copilot.showLogs",
        "title": "%responses-copilot.command.showLogs%"
      },
      {
        "command": "responses-copilot.openRequestDumpsFolder",
        "title": "%responses-copilot.command.openRequestDumpsFolder%"
      }
    ],
    "walkthroughs": [
      {
        "id": "responsesGettingStarted",
        "title": "%responses-copilot.walkthrough.title%",
        "description": "%responses-copilot.walkthrough.description%",
        "steps": [
          {
            "id": "setApiKey",
            "title": "%responses-copilot.walkthrough.setApiKey.title%",
            "description": "%responses-copilot.walkthrough.setApiKey.description%",
            "media": {
              "markdown": "resources/walkthrough/set-api-key.md"
            },
            "completionEvents": [
              "onCommand:responses-copilot.setApiKey"
            ]
          },
          {
            "id": "showModels",
            "title": "%responses-copilot.walkthrough.showModels.title%",
            "description": "%responses-copilot.walkthrough.showModels.description%",
            "media": {
              "markdown": "resources/walkthrough/show-models.md"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%responses-copilot.walkthrough.advancedSettings.title%",
            "description": "%responses-copilot.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "resources/walkthrough/advanced-settings.md"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%responses-copilot.config.title%",
      "properties": {
        "responses-copilot.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "%responses-copilot.config.baseUrl.description%"
        },
        "responses-copilot.maxOutputTokens": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%responses-copilot.config.maxOutputTokens.description%"
        },
        "responses-copilot.modelMaxInputTokensDefault": {
          "type": "number",
          "default": 272000,
          "minimum": 1,
          "description": "%responses-copilot.config.modelMaxInputTokensDefault.description%"
        },
        "responses-copilot.modelMaxOutputTokensDefault": {
          "type": "number",
          "default": 128000,
          "minimum": 1,
          "description": "%responses-copilot.config.modelMaxOutputTokensDefault.description%"
        },
        "responses-copilot.modelTokenOverrides": {
          "type": "object",
          "default": {},
          "markdownDescription": "%responses-copilot.config.modelTokenOverrides.description%"
        },
        "responses-copilot.forceOverrideModelTokenSettings": {
          "type": "boolean",
          "default": false,
          "description": "%responses-copilot.config.forceOverrideModelTokenSettings.description%"
        },
        "responses-copilot.modelListTtlMinutes": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "%responses-copilot.config.modelListTtlMinutes.description%"
        },
        "responses-copilot.reasoningEffortDefault": {
          "type": "string",
          "default": "medium",
          "enum": [
            "none",
            "minimal",
            "low",
            "medium",
            "high",
            "xhigh"
          ],
          "description": "%responses-copilot.config.reasoningEffortDefault.description%"
        },
        "responses-copilot.streamingTransport": {
          "type": "string",
          "default": "websocketPreferred",
          "enum": [
            "websocketPreferred",
            "httpOnly",
            "websocketOnly"
          ],
          "enumItemLabels": [
            "%responses-copilot.config.streamingTransport.websocketPreferred.label%",
            "%responses-copilot.config.streamingTransport.httpOnly.label%",
            "%responses-copilot.config.streamingTransport.websocketOnly.label%"
          ],
          "markdownEnumDescriptions": [
            "%responses-copilot.config.streamingTransport.websocketPreferred.description%",
            "%responses-copilot.config.streamingTransport.httpOnly.description%",
            "%responses-copilot.config.streamingTransport.websocketOnly.description%"
          ],
          "markdownDescription": "%responses-copilot.config.streamingTransport.description%"
        },
        "responses-copilot.experimental.stabilizeToolList": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "%responses-copilot.config.experimental.stabilizeToolList.description%",
          "tags": [
            "experimental"
          ]
        },
        "responses-copilot.debugMode": {
          "type": "string",
          "default": "minimal",
          "enum": [
            "minimal",
            "metadata",
            "verbose"
          ],
          "enumItemLabels": [
            "%responses-copilot.config.debugMode.minimal.label%",
            "%responses-copilot.config.debugMode.metadata.label%",
            "%responses-copilot.config.debugMode.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%responses-copilot.config.debugMode.minimal.description%",
            "%responses-copilot.config.debugMode.metadata.description%",
            "%responses-copilot.config.debugMode.verbose.description%"
          ],
          "markdownDescription": "%responses-copilot.config.debugMode.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "vscode:prepublish": "bash .github/scripts/prepare-marketplace-readme.sh && npm run compile",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "oxlint",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "package": "vsce package --readme-path dist/README.marketplace.md -o dist/",
    "login": "vsce login Vizards"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.116.0",
    "@types/ws": "^8.18.1",
    "@vscode/vsce": "^3.9.1",
    "ovsx": "0.10.12",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3"
  }
}
